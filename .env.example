NODE_ENV=development
PORT=5050

# Database and queue
DATABASE_URL=postgresql://wearelazydev:wearelazydev@localhost:5432/wearelazydev?schema=public
REDIS_URL=redis://localhost:6379
START_WORKERS=true
WORKER_CONCURRENCY=3

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Local MVP modes
MOCK_AI=true
MOCK_PAYMENTS=true

# AI provider, used when MOCK_AI=false
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
CLAUDE_MODEL=claude-sonnet-4-6

# Business model and AI metering
CREDIT_USD_VALUE=0.01
CREATOR_REVENUE_SHARE_BPS=6000
DEFAULT_AI_MARKUP_BPS=25000
MIN_CONSUME_CHARGE_CREDITS=1
# Optional emergency JSON override for model prices per 1M tokens.
# Normal pricing lives in the AiModelPricing table and is seeded by prisma/seed.js.
# Example: {"openai":{"gpt-5.4":{"input":2.5,"output":15}},"anthropic":{"claude-sonnet-4-6":{"input":3,"output":15}}}
AI_PRICING_JSON=

# Celo blockchain config
# Celo Mainnet chain ID is 42220. Celo Sepolia is 11142220.
CELO_CHAIN_ID=42220
RPC_URL=
BOUNTY_CONTRACT_ADDRESS=
AGENT_RENTAL_CONTRACT_ADDRESS=
TREASURY_ADDRESS=

# MiniPay backend integration
MINIPAY_APP_ID=
# Keep addresses empty until verified by the smart contract/frontend team.
# MiniPay user-facing flows should use stablecoin wording and Network fee wording.
MINIPAY_SUPPORTED_TOKENS_JSON=[{"symbol":"USDC","decimals":6,"address":""},{"symbol":"USDT","decimals":6,"address":""},{"symbol":"USDm","decimals":18,"address":""}]

# Existing GitHub OAuth and Reclaim zkTLS proof routes
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
RECLAIM_ID=
RECLAIM_SECRET=
